<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Checker Proposal Seminar</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f7f6; margin: 0; padding: 50px; }
        .container { max-width: 600px; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); margin: auto; }
        h2 { text-align: center; color: #333; }
        label { font-weight: bold; margin-top: 15px; display: block; }
        input[type="text"], input[type="file"] { width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; }
        button { background-color: #007bff; color: white; padding: 12px 20px; border: none; border-radius: 5px; cursor: pointer; width: 100%; margin-top: 20px; font-size: 16px; }
        button:hover { background-color: #0056b3; }
        #hasil { margin-top: 20px; padding: 15px; border-radius: 5px; text-align: center; font-size: 18px; font-weight: bold; display: none; }
        .loader { border: 4px solid #f3f3f3; border-top: 4px solid #007bff; border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 10px auto; display: none; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

<div class="container">
    <h2>AI Checker Proposal Skripsi</h2>
    <form id="aiForm">
        <label>Nama Penguji / Kaprodi:</label>
        <input type="text" id="nama_penguji" name="nama_penguji" required placeholder="Masukkan nama Anda">
        
        <label>Nama Mahasiswa:</label>
        <input type="text" id="nama_mahasiswa" name="nama_mahasiswa" required placeholder="Masukkan nama mahasiswa">
        
        <label>Upload File Proposal (PDF / DOCX):</label>
        <input type="file" id="file_proposal" name="file_proposal" accept=".pdf, .docx" required>
        
        <button type="submit" id="btnCek">Cek Indikasi AI</button>
        <div class="loader" id="loading"></div>
    </form>

    <div id="hasil"></div>
</div>

<script>
document.getElementById('aiForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const formData = new FormData();
    formData.append('nama_penguji', document.getElementById('nama_penguji').value);
    formData.append('nama_mahasiswa', document.getElementById('nama_mahasiswa').value);
    formData.append('file_proposal', document.getElementById('file_proposal').files[0]);

    document.getElementById('btnCek').style.display = 'none';
    document.getElementById('loading').style.display = 'block';
    document.getElementById('hasil').style.display = 'none';

    try {
        // ✅ FIX DI SINI (tanpa slash di depan)
        const response = await fetch('cek-ai', {
            method: 'POST',
            body: formData
        });

        const result = await response.json();
        
        const divHasil = document.getElementById('hasil');
        divHasil.style.display = 'block';
        
        if(result.status === 'sukses') {
            divHasil.style.backgroundColor = '#d4edda';
            divHasil.style.color = '#155724';
            divHasil.innerHTML = "Skor Indikasi AI: " + result.skor + "<br><small>Data telah disimpan ke database.</small>";
        } else {
            divHasil.style.backgroundColor = '#f8d7da';
            divHasil.style.color = '#721c24';
            divHasil.innerHTML = "Error: " + result.pesan;
        }

    } catch (error) {
        alert("Terjadi kesalahan pada server. Cek koneksi atau log error.");
    } finally {
        document.getElementById('btnCek').style.display = 'block';
        document.getElementById('loading').style.display = 'none';
    }
});
</script>

</body>
</html>